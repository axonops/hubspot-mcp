# ─────────────────────────────────────────────────────────────────────────
# Authentication mode: "oauth" (hosted, multi-user, browser login) or "token"
# (local, single static private-app token). If unset, it is inferred:
# oauth when HUBSPOT_CLIENT_ID is present, otherwise token.
# ─────────────────────────────────────────────────────────────────────────
HUBSPOT_AUTH_MODE=oauth

# ── OAuth mode (recommended for Claude Desktop multi-user) ─────────────────
# Create a HubSpot PUBLIC app in your developer account (not a private app):
#   developers.hubspot.com > your app > Auth. Copy the client id/secret and add
#   this server's redirect URL: <HUBSPOT_SERVER_URL>/auth/callback
HUBSPOT_CLIENT_ID=your-public-app-client-id
HUBSPOT_CLIENT_SECRET=your-public-app-client-secret

# Public HTTPS base URL where this server is reachable (no trailing slash).
HUBSPOT_SERVER_URL=https://hubspot-mcp.example.com

# Bind address / port for the HTTP server (behind your TLS proxy).
HUBSPOT_HOST=0.0.0.0
HUBSPOT_PORT=8000

# Optional: override the requested scopes (space- or comma-separated). These
# must also be enabled on the HubSpot app. Leave unset to use the defaults.
# HUBSPOT_SCOPES=crm.objects.contacts.read crm.objects.contacts.write content

# Optional: forward PKCE to HubSpot's authorize endpoint (default false; the
# proxy always enforces PKCE with the MCP client regardless).
# HUBSPOT_FORWARD_PKCE=false

# ── Token mode (local / single user) ──────────────────────────────────────
# HUBSPOT_AUTH_MODE=token
# HUBSPOT_ACCESS_TOKEN=pat-na1-your-private-app-token

# ── Shared (optional) ──────────────────────────────────────────────────────
# HUBSPOT_BASE_URL=https://api.hubapi.com
# HUBSPOT_TIMEOUT=30
